// prisma/schema.prisma
// Rebobina.ai — Schema completo do banco de dados
// PostgreSQL 16 + pgvector

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, unaccent]
}

// ─────────────────────────────────────
// DOMÍNIO: AUTH / USUÁRIOS
// ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  plan          Plan      @default(FREE)
  stateBr       String?   @db.Char(2)    // SP, RJ, etc.
  birthYear     Int?
  onboardingDone Boolean  @default(false)
  lgpdConsentAt DateTime?
  dataSharingOpt Boolean  @default(false)
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  preferences   UserPreference?
  watchlist     WatchlistItem[]
  notifications Notification[]
  searchEvents  SearchEvent[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  favGenres      Int[]    // IDs de genres
  dislikedGenres Int[]
  favPlatforms   Int[]    // IDs de platforms
  favLanguages   String[] // pt, en, es, fr
  maxRuntime     Int?     // minutos
  moodProfile    Json?    // vetor de humor derivado
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─────────────────────────────────────
// DOMÍNIO: CONTEÚDO
// ─────────────────────────────────────

model Title {
  id              String      @id @default(cuid())
  tmdbId          Int         @unique
  imdbId          String?
  type            TitleType   // MOVIE | SERIES | DOCUMENTARY | MINISERIES
  slug            String      @unique

  // Título
  titlePt         String      // Título em PT-BR
  titleOriginal   String      // Título original
  year            Int
  endYear         Int?        // Para séries (null = em andamento)
  runtimeMin      Int?        // Duração em minutos (ep para séries)
  totalEpisodes   Int?
  totalSeasons    Int?

  // Conteúdo
  synopsisPt      String?     @db.Text  // Gerada por IA em PT
  synopsisAiQuote String?     @db.Text  // Frase editorial IA
  aiTrivia        Json?       // Array de curiosidades geradas por IA
  aiOpinionSummary String?    @db.Text  // Resumo de opinião público

  // Mídia
  posterUrl       String?     // TMDB CDN
  backdropUrl     String?
  trailerYoutubeId String?

  // Classificação
  ratingAge       String?     // L, 10, 12, 14, 16, 18
  countries       String[]
  languages       String[]
  spokenLanguages String[]

  // Redes sociais (do filme/série)
  instagramId     String?
  twitterId       String?
  facebookId      String?

  // IA — Tags e categorização (CORE do diferencial)
  embedding       Unsupported("vector(1536)")?  // pgvector
  aiTags          String[]    // tags semânticas livres
  aiMoodTags      String[]    // feel-good, tense, dark, uplifting...
  aiComplexity    String?     // low | medium | high
  aiPace          String?     // slow | medium | fast
  aiAnxietyLevel  Int?        // 1 (zen) a 5 (máxima tensão)
  aiBingeWorthy   Boolean?    // Bom pra maratonar?
  aiSafeFor       String[]    // relaxing, before_sleep, bad_day, kids
  aiNotGoodFor    String[]    // anxiety, sensitive_topics

  // SEO
  seoMetaTitle    String?
  seoMetaDesc     String?     @db.VarChar(160)
  schemaOrg       Json?       // JSON-LD completo

  // Status
  status          TitleStatus @default(DRAFT)
  enrichedAt      DateTime?   // Quando a IA processou
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relações
  genres          TitleGenre[]
  cast            TitleCast[]
  awards          Award[]
  ratings         Rating?
  availability    TitleAvailability[]
  watchlistItems  WatchlistItem[]
  searchEvents    SearchEvent[]
  pageViews       PageView[]

  @@index([slug])
  @@index([type, year])
  @@index([status])
  @@index([aiMoodTags], type: Gin)
  @@index([aiTags], type: Gin)
  @@map("titles")
}

model Genre {
  id      Int    @id @default(autoincrement())
  tmdbId  Int?   @unique
  namePt  String // Drama, Suspense, Comédia...
  nameEn  String
  slug    String @unique

  titles  TitleGenre[]

  @@map("genres")
}

model TitleGenre {
  titleId  String
  genreId  Int
  title    Title  @relation(fields: [titleId], references: [id], onDelete: Cascade)
  genre    Genre  @relation(fields: [genreId], references: [id])

  @@id([titleId, genreId])
  @@map("title_genres")
}

model Person {
  id            String   @id @default(cuid())
  tmdbPersonId  Int      @unique
  name          String
  slug          String   @unique
  photoUrl      String?
  bioPt         String?  @db.Text  // Bio gerada por IA em PT
  birthDate     DateTime?
  deathDate     DateTime?
  nationality   String?

  // Redes sociais
  instagramId   String?
  twitterId     String?
  imdbId        String?

  titleRoles    TitleCast[]

  @@index([slug])
  @@map("people")
}

model TitleCast {
  titleId       String
  personId      String
  role          CastRole    // ACTOR | DIRECTOR | WRITER | DOP | MUSIC | PRODUCER
  characterName String?     // Para atores
  order         Int         @default(0)

  title         Title       @relation(fields: [titleId], references: [id], onDelete: Cascade)
  person        Person      @relation(fields: [personId], references: [id])

  @@id([titleId, personId, role])
  @@index([titleId, role])
  @@map("title_cast")
}

model Rating {
  id                String   @id @default(cuid())
  titleId           String   @unique
  imdbScore         Float?
  imdbVotes         Int?
  rtTomatometer     Int?     // 0-100
  rtAudience        Int?
  metacritic        Int?     // 0-100
  rebobinaScore     Float?   // Média ponderada interna
  aiSentimentPos    Int?     // % positivo
  aiSentimentNeu    Int?
  aiSentimentNeg    Int?
  lastSyncedAt      DateTime @default(now())

  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

model Award {
  id         String      @id @default(cuid())
  titleId    String
  ceremony   String      // Oscar, Cannes, Emmy, BAFTA...
  year       Int
  category   String      // Melhor Filme, Melhor Atriz...
  result     AwardResult // WON | NOMINATED

  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@index([titleId])
  @@map("awards")
}

// ─────────────────────────────────────
// DOMÍNIO: STREAMING
// ─────────────────────────────────────

model Platform {
  id             Int     @id @default(autoincrement())
  name           String  // Netflix, Prime Video, Globoplay...
  slug           String  @unique
  logoUrl        String?
  colorHex       String? // Cor da marca (#E50914)
  baseUrlBr      String? // URL raiz para deeplinks
  tmdbProviderId Int?    @unique
  hasAffiliate   Boolean @default(false)
  affiliateUrl   String?
  isActive       Boolean @default(true)

  availability   TitleAvailability[]
  affiliateClicks AffiliateClick[]

  @@map("platforms")
}

model TitleAvailability {
  id             String         @id @default(cuid())
  titleId        String
  platformId     Int
  country        String         @db.Char(2) @default("BR")
  accessType     AccessType     // SUBSCRIPTION | RENT | BUY | FREE
  priceBrl       Decimal?       @db.Decimal(6, 2)
  deeplinkUrl    String?        @db.Text
  availableFrom  DateTime?
  availableUntil DateTime?
  syncedAt       DateTime       @default(now())
  isActive       Boolean        @default(true)

  title          Title          @relation(fields: [titleId], references: [id], onDelete: Cascade)
  platform       Platform       @relation(fields: [platformId], references: [id])

  @@unique([titleId, platformId, country, accessType])
  @@index([titleId, country, isActive])
  @@index([platformId, isActive])
  @@index([syncedAt])
  @@map("title_availability")
}

model AffiliateClick {
  id         String   @id @default(cuid())
  titleId    String?
  platformId Int
  userId     String?  // Nullable (anônimo)
  sessionId  String?
  source     String?  // search | film_page | home | watchlist
  clickedAt  DateTime @default(now())

  platform   Platform @relation(fields: [platformId], references: [id])

  @@index([platformId, clickedAt])
  @@index([titleId])
  @@map("affiliate_clicks")
}

model SyncJob {
  id               String      @id @default(cuid())
  jobType          SyncJobType // AVAILABILITY | NEW_TITLES | RATINGS | ENRICHMENT
  status           JobStatus   @default(PENDING)
  titlesProcessed  Int         @default(0)
  titlesTotal      Int?
  errorLog         String?     @db.Text
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime    @default(now())

  @@index([jobType, status])
  @@index([createdAt])
  @@map("sync_jobs")
}

// ─────────────────────────────────────
// DOMÍNIO: USUÁRIOS (WATCHLIST)
// ─────────────────────────────────────

model WatchlistItem {
  id              String          @id @default(cuid())
  userId          String
  titleId         String
  status          WatchStatus     @default(WANT)  // WANT | WATCHING | WATCHED
  userRating      Int?            // 1-5 estrelas
  userReview      String?         @db.Text
  notifyAvailable Boolean         @default(true)
  addedAt         DateTime        @default(now())
  watchedAt       DateTime?
  updatedAt       DateTime        @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@index([userId, status])
  @@map("watchlist_items")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType // TITLE_AVAILABLE | LEAVING_SOON | NEW_REC
  titleId     String?
  platformId  Int?
  messagePt   String
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────
// DOMÍNIO: COMPORTAMENTO (dados B2B)
// ─────────────────────────────────────

model SearchEvent {
  id                String   @id @default(cuid())
  userId            String?  // Nullable — anônimos também valem
  sessionId         String?
  rawQuery          String   @db.Text  // "quero algo triste..."
  interpretedIntent Json?    // {type, mood, runtime, platform...}
  resultsShown      String[] // IDs dos títulos mostrados
  resultClicked     String?  // Qual título clicou
  clickPosition     Int?     // 1º, 2º resultado?
  timeToClickMs     Int?     // Tempo de decisão
  refinedQuery      Boolean  @default(false)
  deviceType        String?  // mobile | desktop | tablet
  stateBr           String?  @db.Char(2)
  createdAt         DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  title Title? @relation(fields: [resultClicked], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([stateBr])
  @@map("search_events")
}

model PageView {
  id           String    @id @default(cuid())
  titleId      String?
  userId       String?
  pageType     String    // title | actor | list | search | home
  referrer     String?
  utmSource    String?
  timeOnPageS  Int?
  scrollPct    Int?
  stateBr      String?   @db.Char(2)
  createdAt    DateTime  @default(now())

  title Title? @relation(fields: [titleId], references: [id], onDelete: SetNull)

  @@index([titleId])
  @@index([createdAt])
  @@map("page_views")
}

model BehaviorSnapshot {
  id                  String   @id @default(cuid())
  period              DateTime @db.Date  // Semana de referência
  topSearchedGenres   Json?    // Ranking semanal
  topSearchedMoods    Json?    // humor, triste, ação...
  platformClickShare  Json?    // % por streaming
  topTitlesBr         Json?    // Top 50 buscados no BR
  regionalBreakdown   Json?    // Por estado
  demandNotAvailable  Json?    // Buscados sem streaming BR ← produto B2B
  createdAt           DateTime @default(now())

  @@unique([period])
  @@map("behavior_snapshots")
}

// ─────────────────────────────────────
// DOMÍNIO: SEO / EDITORIAL
// ─────────────────────────────────────

model SeoPage {
  id              String   @id @default(cuid())
  pageType        String   // title | actor | list | genre | platform
  slug            String   @unique
  metaTitle       String?  @db.VarChar(60)
  metaDescription String?  @db.VarChar(160)
  h1              String?
  contentBlocks   Json?    // Seções geradas por IA
  schemaOrg       Json?    // JSON-LD
  canonicalUrl    String?
  lastIndexedAt   DateTime?
  googleImpressions Int?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([slug])
  @@index([pageType])
  @@map("seo_pages")
}

model EditorialList {
  id          String    @id @default(cuid())
  slug        String    @unique
  titlePt     String    // "Melhores thrillers de 2025"
  description String?   @db.Text
  listType    String    // manual | ai_generated | trending
  autoRefresh Boolean   @default(false)
  tags        String[]
  publishedAt DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  items EditorialListItem[]

  @@map("editorial_lists")
}

model EditorialListItem {
  listId        String
  titleId       String
  order         Int
  editorialNote String? @db.Text

  list EditorialList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([listId, titleId])
  @@map("editorial_list_items")
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Plan {
  FREE
  PREMIUM
}

enum TitleType {
  MOVIE
  SERIES
  DOCUMENTARY
  MINISERIES
  SPECIAL
}

enum TitleStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum CastRole {
  ACTOR
  DIRECTOR
  WRITER
  DOP
  MUSIC
  PRODUCER
  EDITOR
}

enum AccessType {
  SUBSCRIPTION
  RENT
  BUY
  FREE
}

enum AwardResult {
  WON
  NOMINATED
}

enum WatchStatus {
  WANT
  WATCHING
  WATCHED
}

enum NotificationType {
  TITLE_AVAILABLE
  LEAVING_SOON
  NEW_RECOMMENDATION
}

enum SyncJobType {
  AVAILABILITY
  NEW_TITLES
  RATINGS
  ENRICHMENT
  SNAPSHOT
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}
