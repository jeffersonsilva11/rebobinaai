# ─────────────────────────────────────
# REBOBINA.AI — Variáveis de Ambiente
# Copie este arquivo para .env.local
# ─────────────────────────────────────

# ── BANCO DE DADOS ──────────────────
# Postgres do docker-compose expõe em 5433 no host (5432 interno)
DATABASE_URL="postgresql://rebobina:senha123@localhost:5433/rebobina_dev?schema=public"

# ── AUTH (NextAuth) ──────────────────
# App roda em 3002 (3000 e 3001 ficam livres para outros projetos)
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"

# Google OAuth
# No console do Google, use redirect URI: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"

# ── REDIS (BullMQ + Cache) ────────────
# Redis do docker-compose expõe em 6380 no host (6379 interno)
REDIS_URL="redis://localhost:6380"

# ── APIs DE CONTEÚDO ─────────────────
TMDB_API_KEY="sua-chave-tmdb"
TMDB_READ_TOKEN="seu-token-de-leitura-tmdb"

OMDB_API_KEY="sua-chave-omdb"

YOUTUBE_API_KEY="sua-chave-youtube"

# ── IA ────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-sua-chave"
OPENAI_API_KEY="sk-sua-chave-openai"

# ── CONFIG DO PIPELINE ────────────────
PIPELINE_BATCH_SIZE="10"
PIPELINE_LANGUAGE="pt-BR"
PIPELINE_COUNTRY="BR"

# ── RATE LIMITING ─────────────────────
SEARCH_RATE_LIMIT="20"

# ── CRON SECRET ───────────────────────
CRON_SECRET="seu-cron-secret"

# ── AMBIENTE ──────────────────────────
NODE_ENV="development"
