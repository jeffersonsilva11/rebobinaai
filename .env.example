# ─────────────────────────────────────
# REBOBINA.AI — Variáveis de Ambiente
# Copie este arquivo para .env.local
# ─────────────────────────────────────

# ── BANCO DE DADOS ──────────────────
DATABASE_URL="postgresql://rebobina:senha123@localhost:5432/rebobina_dev?schema=public"

# ── AUTH (NextAuth) ──────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"

# Google OAuth
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"

# ── REDIS (BullMQ + Cache) ────────────
REDIS_URL="redis://localhost:6379"

# ── APIs DE CONTEÚDO ─────────────────
TMDB_API_KEY="sua-chave-tmdb"
TMDB_READ_TOKEN="seu-token-de-leitura-tmdb"

OMDB_API_KEY="sua-chave-omdb"

YOUTUBE_API_KEY="sua-chave-youtube"

# ── IA ────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-sua-chave"
OPENAI_API_KEY="sk-sua-chave-openai"

# ── CONFIG DO PIPELINE ────────────────
PIPELINE_BATCH_SIZE="10"
PIPELINE_LANGUAGE="pt-BR"
PIPELINE_COUNTRY="BR"

# ── RATE LIMITING ─────────────────────
SEARCH_RATE_LIMIT="20"

# ── CRON SECRET ───────────────────────
CRON_SECRET="seu-cron-secret"

# ── AMBIENTE ──────────────────────────
NODE_ENV="development"
