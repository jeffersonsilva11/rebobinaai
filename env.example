# ─────────────────────────────────────
# REBOBINA.AI — Variáveis de Ambiente
# Copie este arquivo para .env.local
# ─────────────────────────────────────

# ── BANCO DE DADOS ──────────────────
# Local: instale PostgreSQL + extensão pgvector
# docker-compose up -d (ver SETUP.md)
DATABASE_URL="postgresql://rebobina:senha123@localhost:5432/rebobina_dev?schema=public"

# ── AUTH (NextAuth) ──────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"

# Google OAuth — crie em console.cloud.google.com
# OAuth 2.0 Client ID → Web application
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"

# ── REDIS (BullMQ + Cache) ────────────
# Local: redis-cli (ver docker-compose)
# Produção: upstash.com (free tier disponível)
REDIS_URL="redis://localhost:6379"
# Para Upstash em produção:
# REDIS_URL="rediss://default:token@endpoint.upstash.io:port"

# ── APIs DE CONTEÚDO ─────────────────
# TMDB: themoviedb.org/settings/api (gratuito)
TMDB_API_KEY="sua-chave-tmdb"
TMDB_READ_TOKEN="seu-token-de-leitura-tmdb"

# OMDb: omdbapi.com/apikey.aspx (gratuito 1000 req/dia)
OMDB_API_KEY="sua-chave-omdb"

# YouTube Data API v3: console.cloud.google.com
# Ative a API e crie uma chave (gratuita 10k req/dia)
YOUTUBE_API_KEY="sua-chave-youtube"

# ── IA ────────────────────────────────
# Anthropic: console.anthropic.com (Claude Haiku para enriquecimento)
ANTHROPIC_API_KEY="sk-ant-sua-chave"

# OpenAI: platform.openai.com (text-embedding-3-small para vetores)
OPENAI_API_KEY="sk-sua-chave-openai"

# ── CONFIG DO PIPELINE ────────────────
# Quantos títulos processar por rodada de enriquecimento
PIPELINE_BATCH_SIZE="10"
# Idioma padrão para geração de conteúdo
PIPELINE_LANGUAGE="pt-BR"
# País padrão para disponibilidade
PIPELINE_COUNTRY="BR"

# ── RATE LIMITING ─────────────────────
# Máximo de buscas por IP por minuto
SEARCH_RATE_LIMIT="20"

# ── AMBIENTE ──────────────────────────
NODE_ENV="development"
# Em produção, mude para "production" e configure no Vercel
